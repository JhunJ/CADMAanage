# Database (Docker Compose 기본값)
DATABASE_URL=postgresql+psycopg2://caduser:cadpass@localhost:5432/cadmanage
# Async for background (optional)
ASYNC_DATABASE_URL=postgresql+asyncpg://caduser:cadpass@localhost:5432/cadmanage

# ODA File Converter CLI (없으면 DXF 직접 업로드 또는 변환 스킵)
# ODA_FC_PATH=C:/Program Files/ODA/ODAFileConverter/ODAFileConverter.exe
ODA_FC_PATH=

# 파일 저장 루트 (로컬 MVP)
UPLOAD_ROOT=./data/uploads

# 개발 모드: ODA 없을 때 DXF 허용
DEV_ALLOW_DXF_UPLOAD=true
